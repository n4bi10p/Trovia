# ── Google Gemini ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Solana ────────────────────────────────────────────
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# ── Anchor Program IDs (fill after anchor deploy) ─────
AGENT_REGISTRY_PROGRAM_ID=11111111111111111111111111111111
AGENT_ESCROW_PROGRAM_ID=11111111111111111111111111111111
AGENT_EXECUTOR_PROGRAM_ID=11111111111111111111111111111111

# ── Scheduler Keypair (base64 of JSON keypair array) ──
# Generate: solana-keygen new --outfile scheduler-keypair.json
# Encode:   base64 -w 0 scheduler-keypair.json
SCHEDULER_KEYPAIR=

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Cron Security ─────────────────────────────────────
CRON_SECRET=trovia-cron-secret-change-me

# ── Server ────────────────────────────────────────────
PORT=8080
